{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Output schema for secrets-triage skill (flat format matching SKILL.md)",
  "type": "object",
  "required": ["classification", "confidence", "reasoning"],
  "properties": {
    "classification": {
      "enum": ["confirmed_secret", "test_fixture", "placeholder", "revoked", "uncertain"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reasoning": {
      "type": "string",
      "minLength": 20
    },
    "evidence": {
      "type": "object",
      "properties": {
        "secret_type": {
          "type": "string",
          "enum": ["AWS access key", "GitHub token", "password", "API key", "other"]
        },
        "file_context": {
          "type": "string",
          "enum": ["production", "test", "example", "config"]
        },
        "is_test_fixture": {"type": "boolean"},
        "is_placeholder": {"type": "boolean"},
        "in_gitignore": {"type": "boolean"},
        "entropy": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        }
      }
    },
    "risk_statement": {"type": "string"},
    "fix_recommendation": {"type": "string"}
  }
}
