{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Output schema for container-triage skill (flat format matching SKILL.md)",
  "type": "object",
  "required": ["classification", "confidence", "reasoning"],
  "properties": {
    "classification": {
      "enum": ["confirmed", "base_image_only", "build_time_only", "likely_fp", "uncertain"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reasoning": {
      "type": "string",
      "minLength": 20
    },
    "evidence": {
      "type": "object",
      "properties": {
        "package_layer": {
          "type": "string",
          "enum": ["base", "application", "unknown"]
        },
        "vex_status": {
          "type": "string",
          "enum": ["not_affected", "fixed", "affected", "no_vex_data"]
        },
        "vex_justification": {"type": "string"},
        "fix_available": {"type": "boolean"},
        "fix_version": {"type": "string"},
        "runtime_usage": {
          "type": "string",
          "enum": ["confirmed", "likely", "unlikely", "unknown"]
        },
        "package_pinned": {"type": "boolean"}
      }
    },
    "risk_statement": {"type": "string"},
    "fix_recommendation": {"type": "string"}
  }
}
