{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Output schema for fast-triage skill (flat format matching SKILL.md)",
  "type": "object",
  "required": ["classification", "confidence", "reasoning"],
  "properties": {
    "classification": {
      "enum": ["likely_real", "likely_fp", "needs_deep_triage"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reasoning": {
      "type": "string",
      "minLength": 20
    }
  }
}
