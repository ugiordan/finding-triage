{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Output schema for sast-triage skill (flat format matching SKILL.md)",
  "type": "object",
  "required": ["classification", "confidence", "reasoning"],
  "properties": {
    "classification": {
      "enum": ["confirmed", "confirmed_dead_code", "likely_fp", "uncertain"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reasoning": {
      "type": "string",
      "minLength": 20
    },
    "evidence": {
      "type": "object",
      "properties": {
        "call_chain": {"type": "array", "items": {"type": "string"}},
        "mitigations_found": {"type": "array", "items": {"type": "string"}},
        "mitigations_missing": {"type": "array", "items": {"type": "string"}},
        "entry_points": {"type": "array", "items": {"type": "string"}},
        "generated_or_vendored": {"type": "boolean"}
      }
    },
    "risk_statement": {"type": "string"},
    "fix_recommendation": {"type": "string"}
  }
}
